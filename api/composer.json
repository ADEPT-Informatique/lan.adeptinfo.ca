{
  "name": "adept-informatique/lan",
  "description": "API du site web du LAN de l'ADEPT",
  "keywords": [
    "lan-party",
    "Web-API",
    "lumen"
  ],
  "license": "GPL-3.0",
  "type": "project",
  "require": {
    "php": ">=7.3",
    "laravel/lumen-framework": "7.0.2",
    "vlucas/phpdotenv": "4.1.3",
    "flipbox/lumen-generator": "6.0.7",
    "laravel/passport": "8.4.2",
    "dusterio/lumen-passport": "0.2.18",
    "fruitcake/laravel-cors": "1.0.5",
    "dingo/api": "3.0.0",
    "guzzlehttp/guzzle": "6.3.0",
    "seatsio/seatsio-php": "62.3.0",
    "predis/predis": "1.1.1",
    "league/flysystem": "1.0.66",
    "caouecs/laravel-lang": "6.0.1",
    "illuminate/mail": "7.3.0",
    "google/apiclient": "2.4.1",
    "ext-json": "*",
    "facebook/graph-sdk": "5.7.0"
  },
  "require-dev": {
    "fzaninotto/faker": "~1.8",
    "phpunit/phpunit": "~7.5",
    "mockery/mockery": "~1.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    },
    "classmap": [
      "tests/TestCase.php",
      "database/"
    ]
  },
  "scripts": {
    "post-root-package-install": [
      "php -r \"copy('.env.example', '.env');\""
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true
  }
}
